{
  "expo": {
    "name": "Hirevia",
    "slug": "hirevia-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/minimal_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F3F3"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F3F3F3"
      },
      "usesCleartextTraffic": true,
      "package": "com.hitesh_mehta.hireviamobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3a022cb1-109f-42d9-9f39-35e25f4d820a"
      }
    },
    "owner": "hitesh_mehta"
  }
}
